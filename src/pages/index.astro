---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteConfig';
const { title, description } = siteConfig;

// Exact layout matching the reference site (estudiomanzanero.com)
// Using exact computed sizes and positions from the browser
const photoBoxes = [
  // 1. Top Left 
  { image: "/portfolio-webp/rect1.webp", class: "w-[8.47vw] aspect-[2/3] top-[0vh] left-[5.42vw]", speed: "0.15", movement: "10", alt: "Photographie éditoriale de mariage - Lucy + Romain", priority: true, link: "/projets/lucy-romain" },
  // 2. Middle Left-ish
  { image: "/portfolio-webp/rect2.webp", class: "w-[13.19vw] aspect-[2/3] top-[11.91vh] left-[39.10vw]", speed: "0.25", movement: "15", alt: "Couple de mariés - Assia + Jérémy", priority: true, link: "/projets/assia-jeremy" },
  // 3. Right edge middle
  { image: "/portfolio-webp/rect3.webp", class: "w-[13.68vw] aspect-[2/3] top-[24.12vh] left-[81.53vw] z-20", speed: "0.08", movement: "8", alt: "Détails floraux - Portfolio", priority: true, link: "/projets" },
  // 4. Bottom Left-ish
  { image: "/portfolio-webp/rect4.webp", class: "w-[12.78vw] aspect-[2/3] top-[47.17vh] left-[16.88vw] z-0", speed: "0.18", movement: "18", alt: "Portrait élégant - Morgane + Franck", priority: true, link: "/projets/morgane-franck" },
  // 5. Bottom Right-ish
  { image: "/portfolio-webp/rect5.webp", class: "w-[12.99vw] aspect-[2/3] top-[59.28vh] left-[57.36vw] z-10", speed: "0.12", movement: "12", alt: "Ambiance de réception - Marion + Boris", priority: true, link: "/projets/marion-boris" },
];
---

<Layout title={title} description={description} hideFooterLogo={true}>
  
  <section class="relative w-full h-[100vh] overflow-hidden flex-col pt-[30vh] bg-surface hidden md:flex">
    
    {/* Background Floating Rectangles */}
    <div class="absolute inset-0 z-0 w-full h-full pointer-events-none">
      {photoBoxes.map((box, index) => (
        <div 
          class={`parallax-box absolute animate-soft-fade pointer-events-auto hidden md:block ${box.class}`} 
          data-speed={box.speed}
        >
          {/* Inner Wrapper for Mouse Movement Parallax */}
          <div 
            class="mouse-parallax-box w-full h-full shadow-2xl overflow-hidden"
            data-movement={box.movement}
          >
            <a href={box.link} class="block w-full h-full cursor-pointer">
              {box.image && <img 
                src={box.image} 
                alt={box.alt} 
                class="w-full h-full object-cover"
                loading={box.priority ? "eager" : "lazy"}
                decoding={box.priority ? "sync" : "async"}
                {...(box.priority ? { fetchpriority: "high" } : {})}
              />}
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* NEW: Top Caption (Separated from main heading) */}
  <section class="w-full bg-surface text-accent pt-4 md:pt-8 pb-8 hidden md:flex justify-center text-center">
    <div class="overflow-hidden">
      <div class="js-top-caption font-sans text-xs md:text-sm uppercase tracking-widest opacity-80">
        PHOTOGRAPHE DE MARIAGE À VIENNE & LYON • STYLE ÉDITORIAL ET AUTHENTIQUE
      </div>
    </div>
  </section>

  {/* NEW: Sticky Scrolling Logo */}
  <div class="fixed top-0 left-0 w-full h-[100dvh] z-[26] pointer-events-none hidden md:flex auto-cols-auto justify-center px-[5%] pb-[4vh] items-end">
    <div id="sticky-logo-wrapper" class="w-max origin-bottom will-change-transform">
      <h1 
        // Removed tracking-widest to bring letters closer together
        class="text-accent leading-[0.85] font-light pointer-events-auto flex justify-center items-baseline mix-blend-difference drop-shadow-sm select-none"
        style="font-family: 'Times New Roman', Times, serif;"
      >
        <span style="font-size: 12vw;">PHOTO</span> 
        {/* Ampersand styled to match text color, italic, and sitting natively on the baseline */}
        <span class="italic px-[0.8vw]" style="font-size: 11vw;">&amp;</span> 
        <span style="font-size: 12vw;">DRAGÉE</span>
      </h1>
    </div>
  </div>

  {/* === HEADING ANIMATION SECTION === */}
  <section class="c-heading js-c-heading w-full bg-surface text-accent pt-8 pb-12 md:pt-16 md:pb-24 hidden md:flex flex-col items-center justify-center text-center overflow-hidden">
    <div class="c-heading__wrapper w-[90%] md:w-[94%] mx-auto flex flex-col items-center gap-8 md:gap-12">
      <div class="c-heading__box-title w-full flex justify-center">
        <h2 class="c-heading__title font-serif text-[10vw] md:text-[7.8vw] leading-[1.1] md:leading-[1.05] tracking-[-0.03em] font-light text-balance m-0 p-0 text-center mx-auto">
          Votre histoire, c’est la vôtre et elle est unique. Mon rôle est de capter cet amour qui vous lie avec sincérité et élégance.
        </h2>
      </div>
      <div class="c-heading__box-info overflow-hidden">
        <div class="c-heading__info font-sans text-xs md:text-sm uppercase tracking-widest opacity-80 mt-4 md:mt-8">
          CAPTURER LA BEAUTÉ DE L'INSTANT, AVOIR L'ŒIL POUR CE QUI COMPTE VRAIMENT
        </div>
      </div>
    </div>
  </section>


  {/* === DESKTOP GRID SECTION === */}
