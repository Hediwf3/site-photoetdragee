<style>
  /* Avagyan-Style Mobile Reveal — slide-up with opacity */
  .mobile-grid-item, .mobile-text-block {
    opacity: 0;
    transform: translateY(25px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mobile-grid-item.revealed, .mobile-text-block.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import SplitType from 'split-type';

  gsap.registerPlugin(ScrollTrigger);

  // Simple Vanilla JS Parallax Effect (Scroll & Mouse)
  const parallaxBoxes = document.querySelectorAll<HTMLElement>('.parallax-box');
  const mouseParallaxBoxes = document.querySelectorAll<HTMLElement>('.mouse-parallax-box');

  // Mouse tracking state
  let mouseX = 0;
  let mouseY = 0;
  let targetX = 0;
  let targetY = 0;

  // Track window center
  let windowWidth = window.innerWidth;
  let windowHeight = window.innerHeight;

  window.addEventListener('resize', () => {
    windowWidth = window.innerWidth;
    windowHeight = window.innerHeight;
  });

  window.addEventListener('mousemove', (e) => {
    // Normalize mouse position between -1 and 1
    targetX = (e.clientX - windowWidth / 2) / (windowWidth / 2);
    targetY = (e.clientY - windowHeight / 2) / (windowHeight / 2);
  });

  // Linear interpolation for smooth trailing
  const lerp = (start: number, end: number, factor: number) => {
    return start + (end - start) * factor;
  };

  const stickyLogo = document.getElementById('sticky-logo-wrapper');

  const updateParallax = () => {
    // 1. SCROLL PARALLAX (Outer box translates Y)
    const scrollY = window.scrollY;
    
    parallaxBoxes.forEach((box) => {
      const speed = parseFloat(box.getAttribute('data-speed') || '0');
      const yOffset = Math.round(-(scrollY * speed));
      box.style.transform = `translate(0px, ${yOffset}px)`;
    });

    // 2. MOUSE PARALLAX (Inner box translates X & Y smoothly)
    // Lerp mouse coordinates towards target
    mouseX = lerp(mouseX, targetX, 0.05); // The lower the factor, the smoother/lazier the trail
    mouseY = lerp(mouseY, targetY, 0.05);

    mouseParallaxBoxes.forEach((innerBox) => {
      const movement = parseFloat(innerBox.getAttribute('data-movement') || '10');
      // Calculate pixel offset (inverses direction so it feels like floating)
      const xOffset = Math.round(-(mouseX * movement));
      const yOffset = Math.round(-(mouseY * movement));
      
      innerBox.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
    });
    
    // 3. STICKY LOGO SCALING & FOOTER TRANSITION
    const targetPlaceholder = document.getElementById('footer-logo-target');

    if (stickyLogo) {
      let rawScale = 1 - (scrollY / 800);
      let scale = Math.max(0.12, Math.min(1, rawScale)); 
      
      let translateX = 0;
      let translateY = 0;

      if (targetPlaceholder) {
         const docHeight = document.body.scrollHeight;
         const maxScroll = docHeight - windowHeight;
         // We wait until the footer is physically entering the screen (last 5% of viewport height)
         // so it never triggers while the user is still reading the bottom of the grid.
         const footerNode = document.querySelector('footer');
         const triggerDistance = footerNode ? footerNode.offsetHeight + (windowHeight * 0.05) : windowHeight * 0.15; 
         const distanceToBottom = maxScroll - scrollY;

         if (distanceToBottom < triggerDistance) {
            // progress goes from 0 to 1 as we reach the bottom
            const progress = 1 - Math.max(0, distanceToBottom / triggerDistance);
            
            // Sine ease-out: incredibly gentle, feels extremely premium and heavily tied 1:1 to the scroll wheel
            const ease = Math.sin((progress * Math.PI) / 2); 
            
            // At the end, we want the logo to be bigger (matches text-3xl / text-5xl of the footer)
            const targetScale = windowWidth > 768 ? 0.30 : 0.60; 
            scale = scale + ((targetScale - scale) * ease);
            
            // Calculate spatial landing based on the actual invisible placeholder in the footer
            const placeRect = targetPlaceholder.getBoundingClientRect();
            
            // Natural center of the original huge Logo on screen
            const screenCenterX = windowWidth / 2;
            const naturalBottom = windowHeight * 0.96; // 100vh - 4vh padding (pb-[4vh])
            
            // Find current unscaled centered width
            const logoNaturalWidth = stickyLogo.offsetWidth; 
            const scaledHalfWidth = (logoNaturalWidth * scale) / 2;
            const currentVisibleLeft = screenCenterX - scaledHalfWidth;
            
            const finalTranslateX = placeRect.left - currentVisibleLeft;
            // Target is bottom, adjusting slightly based on placeholder padding
            const finalTranslateY = (placeRect.bottom - (windowWidth > 768 ? 8 : 4)) - naturalBottom;
            
            translateX = finalTranslateX * ease;
            translateY = finalTranslateY * ease;
         }
      }

      stickyLogo.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
    }

    requestAnimationFrame(updateParallax);
  };

  // Kick off the animation loop
  requestAnimationFrame(updateParallax);

  // GSAP Heading Animation
  const splitTitle = new SplitType('.c-heading__title', { types: 'lines,words' });

  // Add overflow hidden to lines to create clipping mask effect
  const lines = document.querySelectorAll('.c-heading__title .line');
  lines.forEach(line => {
      (line as HTMLElement).style.overflow = 'hidden';
      // Fix for descenders (j, g, p) getting clipped by overflow hidden
      (line as HTMLElement).style.paddingBottom = '0.2em';
      (line as HTMLElement).style.marginBottom = '-0.2em';
  });

  gsap.from(splitTitle.words, {
      scrollTrigger: {
          trigger: '.js-c-heading',
          start: 'top 80%',
      },
      y: '100%',
      opacity: 0,
      duration: 1.8,
      ease: 'power3.out',
      stagger: 0.08
  });

  // Animate the separate top caption
  gsap.from('.js-top-caption', {
      scrollTrigger: {
          trigger: '.js-top-caption',
          start: 'top 85%',
      },
      y: 20,
      opacity: 0,
      duration: 1.5,
      ease: 'power3.out',
  });

  // Animate the bottom info caption
  gsap.from('.c-heading__info', {
      scrollTrigger: {
          trigger: '.js-c-heading',
          start: 'top 80%',
      },
      y: 20,
      opacity: 0,
      duration: 1.5,
      ease: 'power3.out',
      delay: 0.4
  });

  // Mobile Infinite Grid Logic
  const mobileGrid = document.querySelector('.js-mobile-infinite-grid');
  if (mobileGrid && window.innerWidth < 768) {
      // 1. Setup Intersection Observer for ultra-smooth buttery reveal animations
      const revealOptions = {
          root: null,
          rootMargin: "0px 0px -50px 0px", // Trigger slightly before it comes fully in view
          threshold: 0.05
      };

      const revealObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
              if (entry.isIntersecting) {
                  entry.target.classList.add('revealed');
                  // We purposely don't unobserve so that if cloned nodes appear, or user scrolls up, we can reset if needed.
                  // But for pure avagyan style, one-time reveal or re-reveal is fine.
                  observer.unobserve(entry.target); 
              }
          });
      }, revealOptions);

      // Function to attach observer to elements
      const observeItems = (parentNode: ParentNode) => {
          const items = parentNode.querySelectorAll('.mobile-grid-item, .mobile-text-block');
          items.forEach(el => revealObserver.observe(el));
      };

      // Initial observe
      observeItems(document);

      // 2. Infinite Loop Logic
      // Store a full copy of the original nodes HTML to duplicate seamlessly
      const originalHTMLStrings = Array.from(mobileGrid.children).map(node => node.outerHTML);
      
      let isWorking = false;
      const onScroll = () => {
          if (window.innerWidth >= 768) return;
          if (isWorking) return;

          const scrollY = window.scrollY || document.documentElement.scrollTop;
          const viewportHeight = window.innerHeight;
          const bodyHeight = document.documentElement.scrollHeight;

          // If we reach within 1500px of the bottom of the page, append massive chunks!
          if ((scrollY + viewportHeight) >= (bodyHeight - 1500)) {
              isWorking = true;
              
              // Append a full copy of the entire feed seamlessly
              // We inject as string for max performance over 100s of DOM nodes
              const currentHTML = mobileGrid.innerHTML;
              mobileGrid.innerHTML = currentHTML + originalHTMLStrings.join("");
              
              // Re-observe the newly appended items
              observeItems(document);
              
              // Debounce
              setTimeout(() => { isWorking = false; }, 300);
          }
      };

      // Listen to scroll events
      window.addEventListener('scroll', onScroll, { passive: true });
      // Pre-fire once to ensure large enough feed if the screen is super tall
      onScroll();
  }

</script>
