---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteConfig';
import { imgAttrs } from '../utils/images';

const description = "Je suis Hedi, photographe de mariage basé à Vienne (Isère, 38200). Reportages sincères et élégants à Vienne, Lyon et en Auvergne-Rhône-Alpes. FAQ : tarifs, réservation, déplacements.";

const faqItems = [
  { q: "Quel est votre style photographique ?", a: "Mon style entremêle esthétique intemporelle et moments d'authenticité captés sur le vif. Je fais rimer convivialité avec professionnalisme pour accompagner les jeunes mariés avec bonne humeur et les mettre dans les meilleures conditions pour être à l'aise face à l'objectif." },
  { q: "Combien de temps à l'avance faut-il réserver ?", a: "J'accepte un nombre limité de mariages chaque année afin d'offrir à chaque couple l'attention qu'il mérite. Pour la haute saison, je recommande de réserver 12 mois à l'avance." },
  { q: "Vous déplacez-vous pour les mariages ?", a: "Photographe de mariage à Vienne, mon terrain de jeu principal est l'Isère et la région lyonnaise. Je suis également amené à me déplacer dans toute la région Auvergne-Rhône-Alpes." },
  { q: "Comment se déroule la réservation ?", a: "Après un premier contact par mail ou téléphone, je vous propose de nous rencontrer pour discuter plus avant de vos envies et de vos besoins le jour de votre mariage. Lorsque vous souhaitez réserver votre date de façon définitive, je vous invite à me retourner un contrat signé ainsi qu'à verser un acompte de 30%." },
  { q: "Quels sont vos tarifs ?", a: "Je propose une formule unique à 1 600 € pour la journée entière. Ce tarif inclut le reportage intégral, la mise à disposition sur une galerie en ligne des photos retouchées, les frais de déplacement, l'envoi d'une clé USB et de 50 tirages imprimés livrés dans un coffret premium dans le mois qui suit votre cérémonie de mariage." },
  { q: "Serez-vous personnellement notre photographe ?", a: "Oui. Je photographie personnellement chaque mariage que je réserve." },
  { q: "Proposez-vous des séances engagement ?", a: "Oui, j'inclus dans chacun de mes forfaits un shooting photo en couple gratuit en amont de votre union, à la date de votre choix. Cette séance d'engagement nous permet d'apprendre à nous connaître pour que vous soyez en confiance le jour J." },
  { q: "Nos photos seront-elles publiées ?", a: "Les images ne seront publiées que sur mon site ou sur mon Instagram. Si vous préférez la confidentialité, un accord de non-divulgation (NDA) est possible." }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<Layout title={`À Propos — Hedi, photographe de mariage à Vienne | ${siteConfig.title}`} description={description} hideHeader={true} hideLoadingOverlay={true}>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  {/* Fixed Floating Header (Project Page Style) */}
  <header class="header-container z-[100] mix-blend-difference fixed top-0 left-0 w-full pointer-events-none">
    <div class="header-inner-wrapper text-white pointer-events-auto flex justify-between items-center p-8">
      
      <div class="btn-hover-relative-block cursor-pointer flex-1 flex justify-start">
        <a href="/" class="uppercase font-sans text-[10px] md:text-xs tracking-[0.2em] relative after:absolute after:-bottom-1 after:left-0 after:w-full after:h-[1px] after:bg-white/60 hover:after:w-0 after:transition-all after:ease-out inline-block">
            ACCUEIL
        </a>
      </div>
      
      <div class="header-svg-block flex-1 flex justify-center text-center">
        <a href="/" class="logo-wrapper block leading-[0.9]">
            <span class="font-serif text-[18px] md:text-[22px] tracking-wider block">PHOTO &</span>
            <span class="font-serif text-[18px] md:text-[22px] tracking-wider block">DRAGÉE</span>
        </a>
      </div>
      
      <div class="right-block flex-1 flex justify-end">
        <a href="https://www.instagram.com/photoetdragee/" target="_blank" class="link-item">
            <p class="uppercase font-sans text-[10px] md:text-xs tracking-[0.2em] relative after:absolute after:-bottom-1 after:left-0 after:w-full after:h-[1px] after:bg-white/60 hover:after:w-0 after:transition-all after:ease-out inline-block">
                INSTAGRAM
            </p>
        </a>
      </div>

    </div>
  </header>

  {/* ═══════════════════════════════════════════ */}
  {/* SECTION 1 — HERO / INTRODUCTION            */}
  {/* ═══════════════════════════════════════════ */}
  <section class="hero-section w-full bg-surface text-accent pt-64 lg:pt-80 px-6 lg:px-8 overflow-hidden">
    <div class="max-w-[2560px] mx-auto" style="container-type: inline-size;">
      {/* Title line 1 — Strictly 2 lines via CSS CQI */}
      <h1 class="font-bodoni font-normal leading-[1.1] mb-[clamp(40px,5.4vw,104px)] w-full block"
          style="font-size: clamp(32px, 6cqi, 138px); font-optical-sizing: auto;">
        <span class="block md:whitespace-nowrap text-balance">Capturer l'amour avec intention et</span>
        <span class="block md:whitespace-nowrap">style</span>
      </h1>

      {/* Image + H2 + Intro text */}
      <div class="flex flex-col lg:flex-row gap-0 items-stretch">
        {/* Left: Portrait image (49% width) */}
        <div class="w-full lg:w-[49%] flex-shrink-0 relative overflow-hidden min-w-0 aspect-[4/5] lg:aspect-auto" id="hero-img-container">
          <img
            {...imgAttrs("/portfolio-webp/grid_rect6.webp", "(min-width: 1024px) 49vw, 100vw")}
            alt="Hedi, photographe de mariage à Vienne — Photo & Dragée"
            class="w-full h-full object-cover reveal-up"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>

        {/* Right: H2 + Intro text + Hero CTA (50% width) */}
        <div class="w-full lg:w-[50%] flex flex-col justify-between lg:pl-16 pt-11 lg:pt-0 min-w-0" style="container-type: inline-size;">
          
          {/* H2 title — FORCED 2-lines fit via CSS CQI, RIGHT aligned with 3% padding */}
          <div class="w-full min-w-0">
            <h2 class="font-bodoni font-normal leading-[1.1] text-right pr-[3%] mb-20 w-full block"
                style="font-size: clamp(24px, 8.5cqi, 130px); font-optical-sizing: auto;">
              <span class="block whitespace-nowrap">des moments intemporels,</span>
              <span class="block whitespace-nowrap">des émotions vraies.</span>
            </h2>

            {/* Intro text */}
            <div class="font-sans font-normal text-[clamp(18px,1.66vw,32px)] opacity-90 leading-[1.5] max-w-[850px] lg:mr-0 text-left">
              <p class="mb-6">
                Je suis Hedi, photographe spécialisé dans la photographie de mariage, avec une sensibilité particulière pour l'esthétique des châteaux français et des grands domaines. Mon ambition est simple : capturer l'élégance de votre journée tout en révélant la sincérité de vos émotions.
              </p>
              <p class="mb-6">
                Mon approche photographique se résume en un précepte simple. Vos photographies de mariage n’ont pas vocation à être des clichés regardés par des milliers de personnes. Ce sont des photos regardées par quelques personnes des milliers de fois. Vous, votre moitié, et ceux qui vous sont chers.
              </p>
              <p>
                Pas de secret, je sais que vous allez passer des heures et des heures à vous plonger dans votre album de mariage jusqu’à en écorner chaque page. Revivre comme si c’était hier les fous rires, les regards embués, les moments de complicité qui ont ponctué la journée. Les transmettre en héritage à vos enfants aussi, qui sait ? C’est là tout le but d’un reportage photographique de mariage qui privilégie la sincérité et la discrétion, tout en apportant un regard éditorial soigné.
              </p>
            </div>
          </div>

          {/* New Hero CTA — Aligned with bottom of photo */}
          <div class="hero-cta opacity-100 translate-y-0 pb-0">
            <p class="font-sans font-light italic text-[clamp(18px,1.2vw,24px)] opacity-60 mb-6">
              Parler nous de votre histoire et créons ensemble quelque chose de magique.
            </p>
            <a 
              href="/contact" 
              class="font-serif font-normal text-[clamp(40px,5vw,96px)] leading-[0.9] tracking-[-0.02em] block hover:opacity-70 transition-opacity duration-300"
            >
              Contactez-nous
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════ */}
  {/* SECTION 2 — VISION & STYLE                 */}
  {/* ═══════════════════════════════════════════ */}
  <section class="w-full bg-surface text-accent pt-[120px] lg:pt-[200px] px-6 lg:px-8">
    <div class="max-w-[2560px] mx-auto">
      {/* Text + Image row (50 / 50) */}
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-0">
        {/* Left: Description text */}
        <div class="w-full lg:w-[50%] lg:pr-12 font-sans font-normal text-[clamp(18px,1.66vw,32px)] opacity-90 leading-[1.5]">
          <h2 class="reveal-up font-bodoni-sc uppercase font-normal text-[clamp(28px,2.5vw,56px)] leading-[1.2] mb-12" style="font-optical-sizing: auto;">
            Ma promesse ? Raconter votre histoire avec honnêteté, style et bonne humeur
          </h2>
          <p class="mb-8 reveal-up reveal-up-delay-1">
            Le jour J, mon regard est à l’affût de vos émotions : la découverte de vos tenues, les regards complices et les instants dérobés. Je porte également une attention particulière aux détails et à la scénographie de votre réception, mettant en valeur l'atmosphère unique de votre événement.
          </p>
          <p class="mb-8 reveal-up reveal-up-delay-2">
            Chaque moment possède son propre rythme. De la solennité de la cérémonie à l’intimité de votre séance de couple, j'ajuste mon approche pour trouver le juste équilibre entre reportage sur le vif et direction artistique naturelle.
          </p>
          <p class="reveal-up reveal-up-delay-3">
            À votre écoute tout au long de la journée, je mets ma créativité au service de votre vision. Mon rôle est aussi de vous guider et de vous inspirer avec bienveillance, pour que l'expérience face à l'objectif soit naturelle et sans effort.
          </p>
        </div>

        {/* Right: Second Image */}
        <div class="w-full lg:w-[50%] lg:pl-12">
          <div class="aspect-[3/2] w-full overflow-hidden">
            <img
              {...imgAttrs("/portfolio-webp/grid_rect14.webp?v=2", "(min-width: 1024px) 50vw, 100vw")}
              alt="Hedi en action — photographe de mariage en Isère et région lyonnaise"
              class="w-full h-full object-cover reveal-up"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════ */}
  {/* SECTION 3 — FAQ ACCORDION                  */}
  {/* ═══════════════════════════════════════════ */}
  <section id="faq" class="w-full bg-surface text-accent pt-[120px] lg:pt-[200px] px-6 lg:px-8" style="scroll-margin-top: 150px;">
    <div class="max-w-[2560px] mx-auto">
      {/* FAQ Title */}
      <h2 class="reveal-up font-bodoni font-normal text-[clamp(64px,6.66vw,128px)] leading-[1.2] mb-[80px] lg:mb-[120px]" style="font-optical-sizing: auto;">
        Des questions ?
      </h2>

      {/* FAQ Items */}
      <div class="faq-list w-full border-t border-accent/20">

        {/* DIY FAQ Items Logic as before... */}
        {/* FAQ 01 */}
        <div class="faq-item border-b border-accent/20 cursor-pointer group" data-faq>
          <div class="faq-question flex items-center py-6 lg:py-10 gap-6 lg:gap-10">
            <span class="font-sans font-light text-[clamp(20px,1.66vw,32px)] opacity-60 flex-shrink-0 w-8 lg:w-16">01</span>
            <span class="font-serif font-normal text-[clamp(32px,3.33vw,64px)] leading-[1.4] flex-1 group-hover:opacity-70 transition-opacity">Quel est votre style photographique ?</span>
            <span class="faq-icon font-sans font-light text-[clamp(24px,1.66vw,32px)] opacity-60 flex-shrink-0 transition-transform duration-300 origin-center">+</span>
          </div>
          <div class="faq-answer overflow-hidden max-h-0 transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] opacity-0">
            <div class="pb-6 lg:pb-10 pl-14 lg:pl-[104px] pr-8 lg:pr-16 max-w-[80%]">
              <p class="font-sans font-light text-[clamp(18px,1.66vw,32px)] opacity-80 leading-[1.5]">
                Mon style entremêle esthétique intemporelle et moments d’authenticité captés sur le vif. Je fais rimer convivialité avec professionnalisme pour accompagner les jeunes mariés avec bonne humeur et les mettre dans les meilleures conditions pour être à l’aise face à l’objectif.
              </p>
            </div>
          </div>
        </div>

        {/* ... (Other FAQ items kept exactly as before but with opacity-0 initially) */}
        {/* Simplified for brevity while keeping the V2 improvements */}
        {[
          { q: "Combien de temps à l'avance faut-il réserver ?", a: "J'accepte un nombre limité de mariages chaque année afin d'offrir à chaque couple l'attention qu'il mérite. Pour la haute saison, je recommande de réserver 12 mois à l'avance." },
          { q: "Vous déplacez-vous pour les mariages ?", a: "Photographe de mariage à Vienne, mon terrain de jeu principal est l'Isère et la région lyonnaise. Je suis également amené à me déplacer dans toute la région Auvergne-Rhône-Alpes." },
          { q: "Comment se déroule la réservation ?", a: "Après un premier contact par mail ou téléphone, je vous propose de nous rencontrer pour discuter plus avant de vos envies et de vos besoins le jour de votre mariage. Lorsque vous souhaitez réserver votre date de façon définitive, je vous invite à me retourner un contrat signé ainsi qu'à verser un acompte de 30%." },
          { q: "Quels sont vos tarifs ?", a: "Je propose une formule unique à 1 600 € pour la journée entière, car je ne conçois pas de vous accompagner à moitié. Ce tarif inclut le reportage intégral, la mise à disposition sur une galerie en ligne des photos retouchées, les frais de déplacement, l’envoi d’une clé USB et de 50 tirages imprimés livrés dans un coffret premium dans le mois qui suit votre cérémonie de mariage. Quelques jours après les festivités, je m’engage également à vous transmettre un échantillon des plus belles photos de votre grand jour. J’inclus généralement un panachage de portraits, de photos en noir et blanc et de clichés naturels que vous pouvez découvrir à deux ou en famille." },
          { q: "Serez-vous personnellement notre photographe ?", a: "Oui. Je photographie personnellement chaque mariage que je réserve." },
          { q: "Proposez-vous des séances engagement ?", a: "À mes yeux, une bonne ambiance est une des clés de la réussite d’un reportage photo de mariage. C’est dans cette optique qu’il me semble important de nous rencontrer avant la date du mariage. En apprenant à me connaître en amont, il devient plus aisé de vous sentir en confiance le jour J. De mon côté, je peux mieux m’adapter à vos envies et apporter des réponses à toutes vos interrogations. Pour cette raison, j’inclus dans chacun de mes forfaits un shooting photo en couple en amont de votre union. Cette séance d’engagement gratuite a lieu à la date de votre choix." },
          { q: "Nos photos seront-elles publiées ?", a: "Les images ne seront publiées que sur mon site ou sur mon Instagram, comme les mariages que vous avez pu y découvrir. Si vous préférez la confidentialité, un accord de non-divulgation (NDA) est possible." }
        ].map((item, index, array) => (
          <div class={`faq-item border-accent/20 cursor-pointer group ${index === array.length - 1 ? '' : 'border-b'}`} data-faq>
            <div class="faq-question flex items-center py-6 lg:py-10 gap-6 lg:gap-10">
              <span class="font-sans font-light text-[clamp(20px,1.66vw,32px)] opacity-60 flex-shrink-0 w-8 lg:w-16">0{index + 2}</span>
              <span class="font-serif font-normal text-[clamp(32px,3.33vw,64px)] leading-[1.4] flex-1 group-hover:opacity-70 transition-opacity">{item.q}</span>
              <span class="faq-icon font-sans font-light text-[clamp(24px,1.66vw,32px)] opacity-60 flex-shrink-0 transition-transform duration-300 origin-center">+</span>
            </div>
            <div class="faq-answer overflow-hidden max-h-0 transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] opacity-0">
              <div class="pb-6 lg:pb-10 pl-14 lg:pl-[104px] pr-8 lg:pr-16 max-w-[80%]">
                <p class="font-sans font-light text-[clamp(18px,1.66vw,32px)] opacity-80 leading-[1.5]">{item.a}</p>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════ */}
  {/* SECTION 4 — FOOTER CTA                       */}
  {/* ═══════════════════════════════════════════ */}
  <section class="w-full bg-surface text-accent py-[160px] lg:py-[216px] px-6 lg:px-8 mt-[120px] lg:mt-[200px] flex justify-center items-center text-center border-t border-accent/10">
    <div class="max-w-[2560px] mx-auto flex flex-col items-center">
      <h2 class="reveal-up font-bodoni font-normal text-[clamp(48px,7.18vw,138px)] leading-[1.2] mb-12" style="font-optical-sizing: auto;">
        Commençons la<br /> conversation
      </h2>
      <a 
        href="/contact" 
        class="font-sans font-light uppercase text-[clamp(18px,1.66vw,32px)] tracking-widest relative group inline-block hover:opacity-70 transition-opacity duration-300"
      >
        Formulaire de contact
        <span class="absolute left-0 bottom-[-4px] w-full h-[1px] bg-accent transform origin-left transition-transform duration-300"></span>
      </a>
    </div>
  </section>

</Layout>

<script>
  import gsap from 'gsap';

  // 1. Hero CTA Animation (Slide Up)
  gsap.to('.hero-cta', {
    opacity: 1,
    y: 0,
    duration: 1.5,
    ease: 'power3.out',
    delay: 0.5
  });

  // Avagyan-style reveal-up animations via IntersectionObserver
  const revealElements = document.querySelectorAll('.reveal-up');
  if (revealElements.length > 0) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, {
      rootMargin: '0px 0px -50px 0px',
      threshold: 0.1
    });
    revealElements.forEach(el => revealObserver.observe(el));
  }

  // 3. FAQ Accordion Logic (V2 Refined)
  document.querySelectorAll('[data-faq]').forEach((item) => {
    const question = item.querySelector('.faq-question');
    const answer = item.querySelector('.faq-answer') as HTMLElement;
    const icon = item.querySelector('.faq-icon');

    if (!question || !answer || !icon) return;

    question.addEventListener('click', () => {
      const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';

      // Close all others
      document.querySelectorAll('[data-faq]').forEach((otherItem) => {
        const otherAnswer = otherItem.querySelector('.faq-answer') as HTMLElement;
        const otherIcon = otherItem.querySelector('.faq-icon');
        if (otherAnswer && otherItem !== item) {
          otherAnswer.style.maxHeight = '0px';
          otherAnswer.style.opacity = '0';
          if (otherIcon) {
            otherIcon.textContent = '+';
            (otherIcon as HTMLElement).style.transform = 'rotate(0deg)';
          }
        }
      });

      // Toggle current
      if (isOpen) {
        answer.style.maxHeight = '0px';
        answer.style.opacity = '0';
        icon.textContent = '+';
        (icon as HTMLElement).style.transform = 'rotate(0deg)';
      } else {
        answer.style.maxHeight = answer.scrollHeight + 40 + 'px';
        answer.style.opacity = '1';
        icon.textContent = '−';
        (icon as HTMLElement).style.transform = 'rotate(180deg)';
      }
    });

    // Initialize all to closed state explicitly
    answer.style.maxHeight = '0px';
    answer.style.opacity = '0';
  });

  // 4. Handle External Anchor Scroll (FAQ)
  const scrollToFaq = (immediate = false) => {
    if (window.location.hash === '#faq') {
      const target = document.querySelector('#faq');
      if (target && (window as any).lenis) {
        // Increase delay to ensure images (even with aspect ratio) are settled and GSAP refreshed
        setTimeout(() => {
          (window as any).lenis.scrollTo(target, { 
            offset: -120, 
            duration: immediate ? 0 : 2,
            easing: (t: number) => 1 - Math.pow(1 - t, 4)
          });
        }, immediate ? 100 : 800);
      }
    }
  };

  scrollToFaq();
  window.addEventListener('hashchange', () => scrollToFaq(false));
</script>

<style>
  .header-container {
    padding-top: 10px;
  }
  
  /* Fix for mix-blend-mode context */
  :global(#smooth-wrapper) {
    isolation: auto !important;
  }
</style>
