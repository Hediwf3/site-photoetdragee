---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../data/siteConfig';
import { projects } from '../../data/projects';

// 1. Generate a new path for every project
export async function getStaticPaths() {
  return projects.map((project, index) => {
    // Determine the next project for the footer (loop back to 0 if at the end)
    const nextProject = projects[index + 1] || projects[0];
    return {
      params: { slug: project.slug },
      props: { project, nextProject },
    };
  });
}

const { project, nextProject } = Astro.props;

// Split name for elegant typography (e.g. ASSIA + JÉRÉMY -> ASSIA, JÉRÉMY)
const nameParts = project.name.split(' + ');
const firstName = nameParts[0];
const secondName = nameParts.length > 1 ? nameParts[1] : '';
---

<Layout title={`${project.name} | ${siteConfig.title}`} hideFooter={true} hideHeader={true}>
  
  {/* Fixed Floating Header */}
  <header class="sc-3ac9ea57-0 dhbBPG header-container z-[100] mix-blend-difference" style="translate: none; rotate: none; scale: none; transform: translate(0px, 0%);">
    <div class="header-inner-wrapper text-surface pointer-events-auto">
      
      <div class="btn-hover-relative-block cursor-pointer">
        <a href="/projets" class="sc-2dab8967-0 iAKUkx comp-text uppercase font-sans text-[10px] md:text-xs tracking-[0.2em] relative after:absolute after:-bottom-1 after:left-0 after:w-full after:h-[1px] after:bg-surface/60 hover:after:w-0 after:transition-all after:ease-out inline-block">
            RETOUR
        </a>
      </div>
      
      <div class="header-svg-block">
        <a href="/" class="link-item logo-wrapper text-center block leading-[0.9]">
            <span class="font-serif text-[18px] md:text-[22px] tracking-wider block">PHOTO &</span>
            <span class="font-serif text-[18px] md:text-[22px] tracking-wider block">DRAGÉE</span>
        </a>
      </div>
      
      <div class="right-block">
        <a href="https://instagram.com" target="_blank" class="link-item">
            <p class="sc-2dab8967-0 iAKUkx comp-text uppercase font-sans text-[10px] md:text-xs tracking-[0.2em] relative after:absolute after:-bottom-1 after:left-0 after:w-full after:h-[1px] after:bg-surface/60 hover:after:w-0 after:transition-all after:ease-out inline-block">
                INSTAGRAM
            </p>
        </a>
      </div>

    </div>
  </header>

  {/* Main Horizontal Scroll Container */}
  <div id="smooth-wrapper" class="w-full overflow-x-hidden text-accent">
    <div id="smooth-content" class="w-full overflow-visible box-border">
      <main class="sc-8550a28d-0 hdxPJb bg-surface relative w-full" id="project-main">
        <div class="scroll-content flex flex-col md:flex-row h-auto md:h-[100dvh] w-full md:w-max" id="scroll-content">
          
          {/* 1. Hero Section */}
          <div class="sc-4626d488-0 lnXPse horizontal-scroll-section relative flex shrink-0 h-auto md:h-[100dvh] w-full md:w-vw">
            <div class="portfolio-main-content">
              
              <div class="left-wrap relative z-20">
                 <div class="left-inner-wrap flex flex-col justify-center h-full">
                    <div class="left-top-wrapper comp-text translate-y-4 opacity-0 flex flex-col gap-6 md:gap-8">
                      <p class="sc-2dab8967-0 iAKUkx portfolio-location uppercase tracking-[0.1em] font-sans text-[30px] md:text-3xl opacity-70">
                        <span class="text-lines-wrapper block text-start relative">
                          <span class="text-lines block text-start relative">{project.location}</span>
                        </span>
                      </p>
                      <h1 class="sc-2dab8967-0 iAKUkx portfolio-title font-serif text-[16vw] lg:text-[7vw] xl:text-[100px] leading-[0.85] tracking-[-0.03em] whitespace-nowrap text-accent w-full js-auto-fit-text">
                        <span class="text-lines-wrapper block text-start relative w-full">
                          <span class="text-lines block text-start relative w-full">{firstName} <span class="font-light mx-4">+</span> {secondName}</span>
                        </span>
                      </h1>
                      <p class="sc-2dab8967-0 iAKUkx portfolio-desc font-serif font-light text-base md:text-xl md:leading-[1.4] opacity-80 max-w-[280px] md:max-w-md mt-4">
                        {project.description}
                      </p>
                    </div>
                 </div>
              </div>
              
              {project.heroImage && (
              <div class="right-wrap relative z-10" style="clip-path: polygon(0px 0%, 100% 0%, 100% 100%, 0px 100%);">
                <div class="sc-cacf51d0-0 kMtdZy image-cont relative h-full w-full overflow-hidden opacity-0 translate-y-[200px]">
                  <img draggable="false" alt="" fetchpriority="high" loading="eager" decoding="async" src={project.heroImage} class="absolute inset-0 w-full h-full object-cover" style="color: transparent;" />
                </div>
              </div>
              )}
            </div>
          </div>

          {/* 2. Gallery Scatter */}
          <div class="sc-134ba46d-0 QZqPL flex flex-col md:flex-row h-auto md:h-[100dvh] shrink-0 items-center w-full md:w-auto">
            <div class="images-content flex flex-col md:flex-row items-center h-auto md:h-[100dvh] w-full px-6 md:px-0">
              {project.gallery.map((img, i) => (
                <div class="image-wrapper gallery-item-wrapper for-desktop-anim for-mobile-anim shrink-0 relative z-10">
                  <div class="image-inner-wrapper js-project-anim w-auto h-full relative overflow-hidden flex items-center justify-center">
                    {i < 2 ? (
                      <img 
                        draggable="false" 
                        alt={`${project.name} photo ${i+1}`} 
                        loading="eager"
                        decoding="sync"
                        src={img} 
                        class="w-auto h-full object-cover block gallery-img" 
                      />
                    ) : (
                      <img 
                        draggable="false" 
                        alt={`${project.name} photo ${i+1}`} 
                        data-src={img}
                        src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3C/svg%3E"
                        class="w-auto h-full object-cover block gallery-img gallery-lazy" 
                      />
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* 3. Next Project Footer */}
          <div class="sc-3a08ca-0 dIcaKI next-project-wrapper flex items-center justify-center shrink-0 h-screen md:h-[100dvh] w-full md:w-[60vw]">
             <div class="portfolio-main-content">
                <div class="left-wrap flex flex-col justify-center items-start w-full px-8 md:px-0 gap-16 md:gap-32">
                  
                  {/* Top Part: Créez vos propres souvenirs */}
                  <div class="top-link-wrapper w-full pt-4 pb-4">
                    <a href="/contact" class="outside-project-link cursor-pointer group block relative opacity-0 translate-y-full next-project-anim inline-block overflow-hidden pb-2">
                      <div class="link-wrapper transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-full flex items-center">
                        <h2 class="font-serif text-[5vw] md:text-[3vw] leading-[1.0] md:leading-[0.85] tracking-[-0.03em] uppercase text-left py-3">
                          Créez Vos<br/>propres souvenirs
                        </h2>
                      </div>
                      <div class="link-wrapper-hover absolute top-full inset-x-0 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-full flex items-center">
                        <h2 class="font-serif text-[5vw] md:text-[3vw] leading-[1.0] md:leading-[0.85] tracking-[-0.03em] uppercase text-left py-3">
                          Créez Vos<br/>propres souvenirs
                        </h2>
                      </div>
                    </a>
                  </div>

                  {/* Bottom Part: Projet suivant */}
                  <div class="bottom-link-wrapper flex flex-col items-start w-full">
                    <div class="mb-4 md:mb-8 pt-4 pb-4">
                      <p class="font-sans uppercase tracking-[0.2em] text-[4vw] md:text-3xl opacity-60 text-left opacity-0 translate-y-full next-project-anim">
                        {nextProject.name}
                      </p>
                    </div>
                    <div class="pt-4 pb-4">
                      <a href={`/projets/${nextProject.slug}`} class="outside-project-link cursor-pointer group block relative opacity-0 translate-y-full next-project-anim inline-block overflow-hidden pb-4">
                        <div class="link-wrapper transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-full flex items-center">
                          <h2 class="font-serif text-[5vw] md:text-[3vw] leading-[1.0] md:leading-[0.85] tracking-[-0.03em] uppercase text-left py-3">
                            Projet suivant
                          </h2>
                        </div>
                        <div class="link-wrapper-hover absolute top-full inset-x-0 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:-translate-y-full flex items-center">
                          <h2 class="font-serif text-[5vw] md:text-[3vw] leading-[1.0] md:leading-[0.85] tracking-[-0.03em] uppercase text-left py-3">
                            Projet suivant
                          </h2>
                        </div>
                      </a>
                    </div>
                  </div>

                </div>
             </div>
          </div>

        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  /* Header Floating Nav */
  .header-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    z-index: 100;
    pointer-events: none;
  }
  .header-inner-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32px;
    width: 100%;
    pointer-events: auto;
  }
  @media (min-width: 768px) {
    .header-inner-wrapper {
      padding: 32px;
    }
  }
  .btn-hover-relative-block, .right-block, .header-svg-block {
    flex: 1;
  }
  .btn-hover-relative-block {
    display: flex;
    justify-content: flex-start;
  }
  .header-svg-block {
    display: flex;
    justify-content: center;
  }
  .right-block {
    display: flex;
    justify-content: flex-end;
  }
  /* Base Structural Classes matching Avagyan Layout */
  .portfolio-main-content {
    display: flex;
    flex-direction: column;
    height: auto;
    width: 100%;
  }
  @media (min-width: 768px) {
    .portfolio-main-content {
      flex-direction: row;
      height: 100dvh;
      width: 100vw;
    }
  }

  .horizontal-scroll-section {
    width: 100%;
    height: auto;
  }
  @media (min-width: 768px) {
    .horizontal-scroll-section {
      width: 100vw;
      height: 100dvh;
    }
  }

  .horizontal-scroll-section .portfolio-main-content {
    padding: 120px 24px 60px; /* Top padding for mobile header */
  }
  @media (min-width: 768px) {
    .horizontal-scroll-section .portfolio-main-content {
      padding: 0 0 0 32px;
    }
  }

  /* Left Wrap controls text block width */
  .left-wrap {
    width: 100%;
    height: auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-bottom: 40px;
  }
  @media (min-width: 768px) {
    .left-wrap {
      width: 31.825vw;
      max-width: 802px;
      height: 100%;
      margin-bottom: 0;
    }
  }

  /* Right Wrap controls Hero Image width */
  .right-wrap {
    display: block;
    width: 100%;
    aspect-ratio: 16/9;
  }
  @media (min-width: 768px) {
    .right-wrap {
      display: flex;
      width: calc(100vw - 32px - min(31.825vw, 802px)); 
      height: 100dvh;
      aspect-ratio: auto;
      padding-left: 3vw;
    }
  }

  /* Gallery Styling (.QZqPL / .images-content) */
  .images-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    padding: 40px 24px;
  }
  @media (min-width: 768px) {
    .images-content {
      flex-direction: row;
      align-items: flex-end; /* Align all images to the bottom */
      padding: 0 15vw 5.5vh 5vw;
      gap: 6vw;
    }
  }

  .gallery-item-wrapper {
    width: 100%;
    height: auto;
  }
  @media (min-width: 768px) {
    .gallery-item-wrapper {
      width: auto;
      height: calc(100dvh - 104px - 5.5vh); /* Desktop precise header height (104px) avoidance */
    }
  }

  .image-inner-wrapper img {
    width: 100%;
    height: auto;
  }
  @media (min-width: 768px) {
    .image-inner-wrapper img {
      width: auto;
      height: 100%;
    }
  }

  /* Next Project Section */
  .next-project-wrapper {
    width: 100%;
    padding: 100px 24px;
  }
  @media (min-width: 768px) {
    .next-project-wrapper {
      width: 60vw;
      padding-left: 5vw;
    }
  }
  .next-project-wrapper .portfolio-main-content {
    width: 100%;
  }
  .next-project-wrapper .left-wrap {
    width: 100%;
    max-width: none;
    padding: 0;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAvagyanScroll() {

    const main = document.getElementById('project-main');
    const scrollContent = document.getElementById('scroll-content');

    if (!main || !scrollContent) return;

    // Remove existing ScrollTriggers to avoid memory leaks on view transitions
    ScrollTrigger.getAll().forEach(trigger => trigger.kill());

    // 0. DYNAMIC FONT SIZING FOR PERFECT 1-LINE FIT
    function optimizeTitleFit() {
      const titleH1 = document.querySelector('.js-auto-fit-text') as HTMLElement;
      if (!titleH1) return;

      // Reset inline style to allow CSS to dictate max size at current breakpoint
      titleH1.style.fontSize = ''; 
      
      const textSpan = titleH1.querySelector('.text-lines') as HTMLElement;
      if (!textSpan) return;

      // Force inline block and max-content to accurately measure true unconstrained width
      textSpan.style.display = 'inline-block';
      textSpan.style.width = 'max-content';

      const availableWidth = titleH1.clientWidth; 
      const actualTextWidth = textSpan.scrollWidth;

      // If the text exceeds the container width, linearly scale the font down
      if (actualTextWidth > availableWidth && availableWidth > 0) {
        const currentStyle = window.getComputedStyle(titleH1);
        const currentFontSize = parseFloat(currentStyle.fontSize);
        // Reduce by an extra 3% to ensure padding and rendering rounding is safe
        const newFontSize = currentFontSize * (availableWidth / actualTextWidth) * 0.97;
        titleH1.style.fontSize = `${newFontSize}px`;
      }
      
      // Restore normal width properties
      textSpan.style.display = 'block';
      textSpan.style.width = '100%';
    }

    // Call it immediately on setup
    optimizeTitleFit();

    // 1. Initial fade in for text
    gsap.to('.comp-text', {
      opacity: 1,
      y: 0,
      duration: 2.0, // Set to 2 seconds as requested
      stagger: 0.1,
      ease: 'power3.out'
    });

    // 1b. Hero Image Entrance Animation (Slide up)
    const heroImage = document.querySelector('.right-wrap .image-cont');
    if (heroImage) {
      // Set initial state before animating
      gsap.set(heroImage, { y: 200, opacity: 0 });
      gsap.to(heroImage, {
        y: 0,
        opacity: 1,
        duration: 2.0, // Slowed down from 1.5
        ease: 'power3.out',
        delay: 0.1 // Slight delay so text starts just before image
      });
    }

    // Directly use scrollWidth mapped against window
    function getScrollAmount() {
      return -(scrollContent.scrollWidth - window.innerWidth);
    }

    // GSAP Timeline for horizontal translation - DESKTOP ONLY
    if (window.innerWidth >= 768) {
      const tween = gsap.to(scrollContent, {
        x: getScrollAmount,
        ease: "none",
        force3D: false,
        id: 'horizontal-tween' // Added ID to retrieve it easily
      });

      // ScrollTrigger to tie horizontal scroll to vertical pinning
      ScrollTrigger.create({
        trigger: main,
        start: "top top",
        end: () => `+=${scrollContent.scrollWidth - window.innerWidth}`,
        pin: true,           // This automatically creates the .pin-spacer behind the scenes
        animation: tween,
        scrub: 0.1,          // Reduced from 1 to 0.1 for instant response
        invalidateOnRefresh: true, // Recalculate on resize
        anticipatePin: 1
      });

      // 2. PARALLAX EFFECT ON HERO TITLE (.left-inner-wrap)
      const leftInnerWrap = document.querySelector('.left-inner-wrap');
      if (leftInnerWrap) {
        gsap.to(leftInnerWrap, {
          x: () => window.innerWidth * 0.45,
          ease: "none",
          scrollTrigger: {
            trigger: main,
            start: "top top",
            end: () => `+=${window.innerWidth * 1.5}`,
            scrub: 0.1,      // Also reduced here for consistency
            invalidateOnRefresh: true
          }
        });
      }
    }

    // 2.5 PROJECT GALLERY ENTRANCE ANIMATION
    const projectImages = gsap.utils.toArray('.js-project-anim');
    if (projectImages.length > 0) {
      projectImages.forEach((img) => {
        const isMobile = window.innerWidth < 768;
        
        gsap.from(img as HTMLElement, {
          x: isMobile ? 0 : 150,
          y: isMobile ? 50 : 0, 
          opacity: 0,
          duration: 1.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: (img as HTMLElement).closest('.gallery-item-wrapper'),
            ...(isMobile ? {} : { containerAnimation: (gsap.getById('horizontal-tween') as any) }), // Special handle for containerAnimation
            start: isMobile ? 'top 90%' : 'left 130%', 
            toggleActions: 'play none none reverse'
          }
        });
      });
    }

    // 3. NEXT PROJECT ENTRANCE ANIMATION
    const nextProjectAnims = gsap.utils.toArray('.next-project-anim');
    if (nextProjectAnims.length > 0) {
      const isMobile = window.innerWidth < 768;
      
      gsap.to(nextProjectAnims, {
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.next-project-wrapper',
          ...(isMobile ? {} : { containerAnimation: (gsap.getById('horizontal-tween') as any) }),
          start: isMobile ? 'top 80%' : 'left 80%', 
          toggleActions: 'play none none reverse'
        }
      });
    }

    // === HORIZONTAL LAZY LOADING ===
    // Native loading="lazy" only works vertically. For GSAP horizontal scroll,
    // we use a custom observer that preloads images 2 viewports ahead.
    const lazyImages = document.querySelectorAll('.gallery-lazy[data-src]');
    if (lazyImages.length > 0) {
      const isMobile = window.innerWidth < 768;
      const lazyObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target as HTMLImageElement;
            if (img.dataset.src) {
              img.src = img.dataset.src;
              delete img.dataset.src;
              img.classList.remove('gallery-lazy');
              lazyObserver.unobserve(img);
              // Refresh GSAP after image loads to recalculate widths
              img.addEventListener('load', () => ScrollTrigger.refresh(), { once: true });
            }
          }
        });
      }, {
        // For horizontal scroll: extend rootMargin to the RIGHT by 200% of viewport
        // For vertical (mobile): extend downward
        rootMargin: isMobile ? '0px 0px 200% 0px' : '0px 300% 0px 0px',
        threshold: 0
      });
      
      lazyImages.forEach(img => lazyObserver.observe(img));
    }

    // Automatically refresh GSAP when images load and change the container's width
    const resizeObserver = new ResizeObserver(() => {
      optimizeTitleFit();
      ScrollTrigger.refresh();
    });
    resizeObserver.observe(scrollContent);
  }

  // Astro View Transitions lifecycle hook
  document.addEventListener('astro:page-load', initAvagyanScroll);
  
  // Fallback for direct loads if event already fired
  if (document.readyState === 'complete') {
     initAvagyanScroll();
  } else {
     window.addEventListener('load', initAvagyanScroll);
  }
</script>
