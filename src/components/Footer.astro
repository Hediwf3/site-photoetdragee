---
import { siteConfig } from '../data/siteConfig';

interface Props {
  hideLogo?: boolean;
}

const { hideLogo = false } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-surface text-accent pt-24 pb-12 px-6 md:px-12 flex flex-col items-center">
  
  <div class="w-full max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-end gap-12 border-t border-accent/10 pt-12">
    
    {/* Brand & Copyright */}
    <div class="flex flex-col gap-4">
      { !hideLogo ? (
        <h2 class="text-3xl md:text-5xl font-serif uppercase tracking-widest font-light">
          {siteConfig.title}
        </h2>
      ) : (
        <div id="footer-logo-target" class="w-[70vw] md:w-[25vw] h-8 md:h-12 pointer-events-none opacity-0"></div>
      ) }
      <p class="text-sm font-sans font-light opacity-75">
        &copy; {currentYear} {siteConfig.title}. Tous droits réservés.
      </p>
    </div>

    {/* Links */}
    <div class="flex flex-col sm:flex-row gap-12 text-sm font-sans uppercase tracking-widest font-light">
      <div class="flex flex-col gap-4">
        <span class="opacity-50 text-xs">Navigation</span>
        {siteConfig.navLinks.map((link) => (
          <a href={link.href} class="hover:italic transition-all duration-300">
            {link.label}
          </a>
        ))}
      </div>
      
      <div class="flex flex-col gap-4">
        <span class="opacity-50 text-xs">Social</span>
        <a href={siteConfig.socials.instagram} target="_blank" rel="noopener noreferrer" class="hover:italic transition-all duration-300">
          Instagram
        </a>
      </div>

      <div class="flex flex-col gap-4">
        <span class="opacity-50 text-xs">Contact</span>
        <a href="#" class="bot-protected-email hover:italic transition-all duration-300" data-p1="photoetdragee" data-p2="gmail.com">Afficher l'email</a>
        <a href="#" class="bot-protected-phone hover:italic transition-all duration-300" data-p1="06" data-p2="52253578">Afficher le numéro</a>
      </div>
    </div>

  </div>

</footer>

<script>
  // Bot protection
  document.querySelectorAll('.bot-protected-email').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const p1 = el.getAttribute('data-p1');
      const p2 = el.getAttribute('data-p2');
      if (p1 && p2) {
        const email = `${p1}@${p2}`;
        const a = document.createElement('a');
        a.href = `mailto:${email}`;
        a.className = el.className;
        a.textContent = email;
        el.replaceWith(a);
      }
    });
  });
  
  document.querySelectorAll('.bot-protected-phone').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const pre = el.getAttribute('data-p1');
      const suf = el.getAttribute('data-p2');
      if (pre && suf) {
        const phone = `${pre}${suf}`;
        const formatted = `${pre} ${suf.match(/.{1,2}/g)?.join(' ')}`;
        const a = document.createElement('a');
        a.href = `tel:${phone}`;
        a.className = el.className;
        a.textContent = formatted;
        el.replaceWith(a);
      }
    });
  });
</script>
