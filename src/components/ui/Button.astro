---
// src/components/ui/Button.astro
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
}

const { 
  href, 
  type = 'button', 
  variant = 'outline',
  class: className = ''
} = Astro.props;

// Editorial Button Styles
const baseStyles = "inline-block px-8 py-3 text-sm uppercase tracking-widest transition-all duration-300 font-sans font-light";

const variantStyles = {
  primary: "bg-accent text-surface hover:bg-surface hover:text-accent border border-accent",
  outline: "border border-accent text-accent hover:bg-accent hover:text-surface",
  ghost: "text-accent hover:italic hover:opacity-70",
};

const combinedClasses = `${baseStyles} ${variantStyles[variant]} ${className}`;
---

{href ? (
  <a href={href} class={combinedClasses}>
    <slot />
  </a>
) : (
  <button type={type} class={combinedClasses}>
    <slot />
  </button>
)}
